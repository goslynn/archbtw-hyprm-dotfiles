#!/bin/sh
# Wrapper de Sioyek (AppImage Qt5) para HiDPI bajo XWayland en Hyprland.
# Requiere xwayland:force_zero_scaling=true (ver ~/.config/hypr/conf.d/xwayland.conf):
# con eso la ventana se dibuja a píxel nativo y Qt escala la UI con estas variables,
# de modo que el texto del PDF sale nítido y la interfaz mantiene un tamaño usable.
export QT_AUTO_SCREEN_SCALE_FACTOR=1
export QT_ENABLE_HIGHDPI_SCALING=1

# Prioriza el AppImage local; si no está, cae al sioyek del sistema (pacman/AUR).
APP="$HOME/Applications/Sioyek-x86_64.AppImage"
if [ -x "$APP" ]; then
    exec "$APP" "$@"
else
    exec /usr/bin/sioyek "$@"
fi
